  m_Script: {fileID: 11500000, guid: 51fc989f0f5de3043b8ea24d0f9ab57c, type: 3}
  m_Name: Dialogo inicial
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - text: "El laboratorio del viejo Mihail... Todo est\xE1 desierto, pero el aire
      se siente denso. Esa extra\xF1a neblina que reportaron en los distritos de
      Capril\xF3polis tuvo que salir de aqu\xED."
    portrait: {fileID: 21300000, guid: d072a5b7401177c48bb0192ed284f942, type: 3}
  - text: "Mihail no es de los que dejan el laboratorio abierto. Algo sali\xF3 muy
      mal con sus experimentos de biotecnolog\xEDa aplicada."
    portrait: {fileID: 21300000, guid: d072a5b7401177c48bb0192ed284f942, type: 3}
  dialogueID: 0
