  m_Script: {fileID: 11500000, guid: 51fc989f0f5de3043b8ea24d0f9ab57c, type: 3}
  m_Name: Dialogo Registro de Audio
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - text: "Bit\xE1cora de investigaci\xF3n... El proyecto de multiplicaci\xF3n biotecnol\xF3gica
      de frutos secos iba a terminar con la escasez de alimentos en la ciudad. Pero
      Pete..."
    portrait: {fileID: 21300000, guid: 4a4a91b97ec8cbe4aafcf715be4f4eab, type: 3}
  - text: "\xA1Pete alter\xF3 los protocolos de mutaci\xF3n molecular a mis espaldas!
      Quer\xEDa duplicar la producci\xF3n en masa salt\xE1ndose la fase de estabilizaci\xF3n...
      \xA1Dios m\xEDo, la incubadora principal est\xE1 cambiando!"
    portrait: {fileID: 21300000, guid: 4a4a91b97ec8cbe4aafcf715be4f4eab, type: 3}
  - text: "\xBFPete Caprotesto saboteando el proyecto por pura codicia? Sab\xEDa
      que era un tibur\xF3n corporativo, pero esto es negligencia criminal. Desat\xF3
      algo horrible aqu\xED dentro."
    portrait: {fileID: 21300000, guid: d072a5b7401177c48bb0192ed284f942, type: 3}
  dialogueID: 5
