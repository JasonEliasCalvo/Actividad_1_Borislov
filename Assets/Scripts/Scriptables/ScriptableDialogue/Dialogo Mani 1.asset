  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 51fc989f0f5de3043b8ea24d0f9ab57c, type: 3}
  m_Name: Dialogo Mani 1
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - text: "\xBFManny Toxin? \xBFUn maldito cacahuate mutante con intelecto propio
      est\xE1 envenenando Capril\xF3polis? Y el cobarde de Pete se dio a la fuga
      con los datos despu\xE9s de causar este desastre"
    portrait: {fileID: 21300000, guid: d072a5b7401177c48bb0192ed284f942, type: 3}
  - text: "\xA1Pete alter\xF3 los protocolos de mutaci\xF3n molecular a mis espaldas!
      Quer\xEDa duplicar la producci\xF3n en masa salt\xE1ndose la fase de estabilizaci\xF3n...
      \xA1Dios m\xEDo, la incubadora principal est\xE1 cambiando!"
    portrait: {fileID: 21300000, guid: d072a5b7401177c48bb0192ed284f942, type: 3}
  - text: "Tengo que detener la propagaci\xF3n de esa toxina antes de que consuma
      la ciudad entera. El rastro de destrucci\xF3n me llevar\xE1 hasta Pete y esa
      cosa."
    portrait: {fileID: 21300000, guid: d072a5b7401177c48bb0192ed284f942, type: 3}
  dialogueID: 3
